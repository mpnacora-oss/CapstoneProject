{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Start Backend",
      "program": "${workspaceFolder}/backend/src/server.js",
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/backend/.env",
      "console": "integratedTerminal",
      "runtimeExecutable": "node",
      "preLaunchTask": "npm-install-backend"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Start Frontend",
      "program": "${workspaceFolder}/frontend/node_modules/next/dist/bin/next",
      "args": ["dev", "-p", "3002"],
      "cwd": "${workspaceFolder}/frontend",
      "console": "integratedTerminal",
      "env": { "NEXT_TELEMETRY_DISABLED": "1" },
      "runtimeExecutable": "node",
      "preLaunchTask": "npm-install-frontend",
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "http://localhost:3002"
      }
    }
  ],
  "compounds": [
    {
      "name": "Full System (F5)",
      "configurations": ["Start Backend", "Start Frontend"]
    }
  ]
}
